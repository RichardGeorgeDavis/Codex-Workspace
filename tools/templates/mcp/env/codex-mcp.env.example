# Local-only Codex Workspace MCP environment variables.
#
# Export these before launching `codex` if you want the current shell to pass
# the credentials through to remote MCP servers.

# Optional. Context7 still works without this key, but rate limits are lower.
# export CONTEXT7_API_KEY="..."

# Optional if you prefer OAuth for GitHub. When set, the managed GitHub profile
# uses this token as the remote bearer token.
# export GITHUB_PAT="..."
