#!/usr/bin/env sh
set -eu

. "$(CDPATH= cd -- "$(dirname "$0")/../scripts" && pwd)/mempalace-env.sh"

if ! mempalace_repo_exists; then
  printf 'MemPalace repo is missing. Run: %s\n' "$mempalace_install_command" >&2
  exit 1
fi

if ! command -v git >/dev/null 2>&1; then
  printf 'git is required to sync MemPalace.\n' >&2
  exit 1
fi

if [ -n "$(git -C "$mempalace_repo" status --porcelain)" ]; then
  printf 'Refusing to sync a dirty MemPalace working tree: %s\n' "$mempalace_repo" >&2
  exit 1
fi

current_branch=$(git -C "$mempalace_repo" symbolic-ref --quiet --short HEAD 2>/dev/null || printf 'main')
upstream_url=""
origin_url=""
push_remote="${MEMPALACE_PUSH_REMOTE:-}"

if git -C "$mempalace_repo" remote get-url upstream >/dev/null 2>&1; then
  upstream_url=$(git -C "$mempalace_repo" remote get-url upstream)
fi

if git -C "$mempalace_repo" remote get-url origin >/dev/null 2>&1; then
  origin_url=$(git -C "$mempalace_repo" remote get-url origin)
fi

if [ -z "$push_remote" ]; then
  push_remote=$(git -C "$mempalace_repo" config --get mempalace.pushRemote 2>/dev/null || true)
fi

if [ -n "$upstream_url" ]; then
  printf 'Fetching upstream...\n'
  git -C "$mempalace_repo" fetch upstream --prune
  printf 'Fast-forwarding %s from upstream/main...\n' "$current_branch"
  git -C "$mempalace_repo" checkout "$current_branch"
  git -C "$mempalace_repo" merge --ff-only upstream/main
elif [ -n "$origin_url" ]; then
  printf 'Fetching origin...\n'
  git -C "$mempalace_repo" fetch origin --prune
  printf 'Fast-forwarding %s from origin/%s...\n' "$current_branch" "$current_branch"
  git -C "$mempalace_repo" checkout "$current_branch"
  git -C "$mempalace_repo" merge --ff-only "origin/$current_branch"
else
  printf 'No git remote is configured for %s\n' "$mempalace_repo" >&2
  exit 1
fi

if [ -n "$push_remote" ]; then
  if ! git -C "$mempalace_repo" remote get-url "$push_remote" >/dev/null 2>&1; then
    printf 'Configured push remote does not exist: %s\n' "$push_remote" >&2
    exit 1
  fi

  push_url=$(git -C "$mempalace_repo" remote get-url "$push_remote")

  if [ -n "$upstream_url" ] && [ "$push_url" = "$upstream_url" ]; then
    printf 'Refusing to push to upstream remote %s (%s)\n' "$push_remote" "$push_url" >&2
    exit 1
  fi

  printf 'Pushing %s to %s...\n' "$current_branch" "$push_remote"
  git -C "$mempalace_repo" push "$push_remote" "$current_branch"
else
  printf 'Skipping push: no project push remote is configured.\n'
fi

record_mempalace_event "sync"
