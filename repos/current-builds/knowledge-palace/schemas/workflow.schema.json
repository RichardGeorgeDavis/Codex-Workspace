{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow",
  "type": "object",
  "required": [
    "id",
    "workflow_name",
    "goal",
    "steps",
    "preconditions",
    "decision_points",
    "risks",
    "best_use_cases",
    "source_refs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^wf_[a-z0-9]+(?:-[a-z0-9]+)*-\\d{3}$"
    },
    "workflow_name": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "best_use_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
