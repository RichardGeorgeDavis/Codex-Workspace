{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Export Manifest",
  "type": "object",
  "required": [
    "target",
    "slug",
    "generated_on",
    "files"
  ],
  "properties": {
    "target": {
      "type": "string",
      "enum": [
        "markdown",
        "chatgpt",
        "codex",
        "cursor",
        "notebooklm",
        "gemini",
        "antigravity"
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "generated_on": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
