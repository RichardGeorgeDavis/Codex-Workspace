{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Card",
  "type": "object",
  "required": [
    "id",
    "title",
    "slug",
    "type",
    "topics",
    "source_refs",
    "statement_types_present",
    "verification_state",
    "created_by",
    "date_created"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^card_[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "type": {
      "type": "string",
      "enum": [
        "event-insight"
      ]
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "statement_types_present": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_state": {
      "type": "string",
      "enum": [
        "draft",
        "unreviewed",
        "reviewed",
        "verified",
        "deprecated"
      ]
    },
    "created_by": {
      "type": "string"
    },
    "date_created": {
      "type": "string"
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
